{
  "name": "@agent-toolbox/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "agent-toolbox-server": "./src/index.ts"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:real:android": "RUN_REAL_ANDROID=1 vitest run --config vitest.real.config.ts",
    "test:real:ios": "RUN_REAL_IOS=1 vitest run --config vitest.real.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/multipart": "^8.3.0",
    "fastify": "^4.28.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
